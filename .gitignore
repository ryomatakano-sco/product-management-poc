# ─────────────────────────────────────────────────────────────────────────────
# Secrets — never commit
# ─────────────────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
!.env.example

# Local dev TLS certs (self-signed, for the phone-camera HTTPS path). The
# private key must never be committed — regenerate locally via gen-dev-cert.
backend/.certs/
*.key
*.crt
*.pem

# ─────────────────────────────────────────────────────────────────────────────
# Local-only Claude context — not for the public repo. Holds internal
# trade-off notes + conversation TL;DR that don't belong on GitHub.
# Regenerate or update locally; never push.
# ─────────────────────────────────────────────────────────────────────────────
CONTEXT.md

# ─────────────────────────────────────────────────────────────────────────────
# Python (backend/)
# ─────────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ─────────────────────────────────────────────────────────────────────────────
# Node / frontend tooling (mostly not used here, but harmless to ignore)
# ─────────────────────────────────────────────────────────────────────────────
node_modules/
dist/
.vite/
*.tsbuildinfo

