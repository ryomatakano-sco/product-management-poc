# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in the values you need.
# Variables left commented use the defaults defined in backend/app/config.py.
# ─────────────────────────────────────────────────────────────────────────────


# ── Database ────────────────────────────────────────────────────────────────
# Two ways to configure. Pick one.
#
#   (A) DATABASE_URL — full SQLAlchemy URL. Wins when set; ignore DB_* below.
#       Useful for production or when you need a non-standard dialect/driver.
#
#   (B) DB_* split vars — assembled into a URL with the async aiomysql driver.
#       This is the recommended path for local dev.
#
# IMPORTANT: when the api runs inside Docker, "localhost" refers to the api
# container itself — not your host machine. Use `host.docker.internal` to
# reach a MySQL that's running directly on the host (Docker Desktop maps it
# automatically on Windows and macOS). When running uvicorn natively, set
# DB_HOST=127.0.0.1 instead.

# --- (A) Full URL ----------------------------------------------------------
# DATABASE_URL=mysql+aiomysql://root:admin@host.docker.internal:3306/maindb

# --- (B) Split vars --------------------------------------------------------
DB_HOST=host.docker.internal
DB_PORT=3306
DB_USER=root
DB_PASSWORD=admin
DB_NAME=maindb


# ── AI Assist (product lookup) ──────────────────────────────────────────────
# Set OPENAI_API_KEY to use the real OpenAI Agents pipeline (web search +
# structured extraction). Leave it commented out — or set MOCK_AI=1 — to use
# the built-in canned mock data. Mock mode is free, instant, and deterministic,
# so demos work end-to-end without an API key.
#
# OPENAI_API_KEY=sk-...
# MOCK_AI=1


# ── Multi-tenancy (frontend default) ────────────────────────────────────────
# The frontend reads its active Store ID from localStorage (key `sco.storeId`)
# and falls back to 1. There's no server-side default — every API call must
# include the `X-Store-Id` header. This is here only as a reminder.
#
# DEFAULT_STORE_ID=1   # not currently consumed by any code; informational only
